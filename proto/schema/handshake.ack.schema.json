{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x4mp.dev/schema/handshake.ack.schema.json",
  "title": "handshake.ack",
  "type": "object",
  "required": [
    "v",
    "type",
    "session_id",
    "seq",
    "timestamp_sim",
    "sender_id",
    "authority",
    "payload"
  ],
  "properties": {
    "v": { "type": "integer", "const": 1 },
    "type": { "type": "string", "const": "handshake.ack" },
    "session_id": { "type": "string", "format": "uuid" },
    "seq": { "type": "integer", "minimum": 0 },
    "timestamp_sim": { "type": "number" },
    "sender_id": { "type": "string", "format": "uuid" },
    "authority": { "type": "string", "enum": ["server"] },
    "payload": {
      "type": "object",
      "required": ["client_id", "session_id", "display_name", "proto_version"],
      "properties": {
        "client_id": { "type": "string", "format": "uuid" },
        "session_id": { "type": "string", "format": "uuid" },
        "display_name": { "type": "string", "minLength": 1, "maxLength": 24 },
        "proto_version": { "type": "integer" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
