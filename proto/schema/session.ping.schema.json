{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x4mp.dev/schema/session.ping.schema.json",
  "title": "session.ping",
  "type": "object",
  "required": [
    "v",
    "type",
    "session_id",
    "seq",
    "timestamp_sim",
    "sender_id",
    "authority",
    "payload"
  ],
  "properties": {
    "v": { "type": "integer", "const": 1 },
    "type": { "type": "string", "const": "session.ping" },
    "session_id": { "type": "string", "format": "uuid" },
    "seq": { "type": "integer", "minimum": 0 },
    "timestamp_sim": { "type": "number" },
    "sender_id": { "type": "string", "format": "uuid" },
    "authority": { "type": "string", "enum": ["client", "host", "server"] },
    "payload": { "type": "object" }
  },
  "additionalProperties": false
}
