# Human: Default URLs/versions for the local Docker + Windows host dev stack.
# Agent: READ by start-host.ps1; COPY to .env to override (gitignored).

# X4 install extensions folder(s) for sync-mod.ps1 (semicolon-separated for multiple installs).
# The spike mod is deployed (junction or copy) into <dir>\x4mp_spike under each path.
X4MP_X4_EXTENSIONS_DIR=C:\Program Files (x86)\Steam\steamapps\common\X4 Foundations\extensions

# SirNuke pipe server (Windows host only — not in Docker)
# https://github.com/bvbohnen/x4-projects/releases
X4MP_PIPE_SERVER_RELEASE_TAG=v1.12
X4MP_PIPE_SERVER_ASSET=sn_x4_python_pipe_server_exe_v1.4.3.zip
X4MP_PIPE_SERVER_DOWNLOAD_URL=https://github.com/bvbohnen/x4-projects/releases/download/v1.12/sn_x4_python_pipe_server_exe_v1.4.3.zip
X4MP_HOST_PORT=7878
X4MP_SERVER_URL=ws://127.0.0.1:7878/ws

# Bridge handshake defaults (M0 dev session)
X4MP_PIPE_NAME=x4mp_bridge
X4MP_DISPLAY_NAME=Player
X4MP_JOIN_CODE=ABCD-1234
X4MP_GAME_VERSION=9.00
X4MP_MODS_FINGERPRINT=sha256:0000
RUST_LOG=x4mp_server=info,x4mp_bridge=info
