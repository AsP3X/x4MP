<?xml version="1.0" encoding="utf-8"?>
<!-- Human: Extension Options submenu — one toggle button (Start/Stop capture labels). -->
<!-- Agent: CALLS Simple_Menu_API Make_Button + Update_Widget; SIGNALS SpikeCapture_Start/Stop. -->
<mdscript name="X4MP_Spike_Menu" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
  <cues>
    <!-- Human: Register spike submenu when SirNuke Simple Menu API reloads. -->
    <!-- Agent: WRITES "X4MP Spike" under Main Menu -> Extension Options. -->
    <cue name="Spike_Register_Options_Menu" instantiate="true">
      <conditions>
        <check_any>
          <event_cue_signalled cue="md.Simple_Menu_API.Reloaded"/>
          <event_cue_signalled cue="md.Setup.Start"/>
        </check_any>
      </conditions>
      <actions>
        <signal_cue_instantly
          cue="md.Simple_Menu_API.Register_Options_Menu"
          param="table[
            $id       = 'x4mp_spike_menu',
            $columns  = 1,
            $title    = 'X4MP Spike',
            $onOpen   = Spike_Build_Options_Menu,
            ]"/>
      </actions>
    </cue>

    <!-- Human: Label for the capture toggle reflects live capture state. -->
    <!-- Agent: READS md.X4MP_Spike_Capture.Globals.$CaptureActive; SETS $CaptureButtonLabel. -->
    <library name="Capture_Button_Label">
      <actions>
        <do_if value="@md.X4MP_Spike_Capture.Globals.$CaptureActive">
          <set_value name="$CaptureButtonLabel" exact="'Stop capture'"/>
        </do_if>
        <do_else>
          <set_value name="$CaptureButtonLabel" exact="'Start capture'"/>
        </do_else>
      </actions>
    </library>

    <!-- Human: Build one toggle row — click flips capture and re-labels the button. -->
    <!-- Agent: CALLS Make_Button with onClick SpikeOption_ToggleCapture. -->
    <cue name="Spike_Build_Options_Menu" instantiate="true">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <include_actions ref="Capture_Button_Label"/>
        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row"/>
        <signal_cue_instantly
          cue="md.Simple_Menu_API.Make_Button"
          param="table[
            $id           = 'x4mp_spike_capture_toggle',
            $col          = 1,
            $text         = table[$text = $CaptureButtonLabel],
            $mouseOverText = 'Toggle Q1 ship sampling (~10 Hz). Run tools/dev-stack/start-host.ps1 first.',
            $onClick      = SpikeOption_ToggleCapture,
            ]"/>
      </actions>
    </cue>

    <!-- Human: Toggle capture on/off and refresh button text in the open menu. -->
    <!-- Agent: SIGNALS SpikeCapture_Start or Stop; UPDATES widget label via Update_Widget. -->
    <cue name="SpikeOption_ToggleCapture" instantiate="true">
      <conditions>
        <event_cue_signalled/>
      </conditions>
      <actions>
        <do_if value="@md.X4MP_Spike_Capture.Globals.$CaptureActive">
          <signal_cue cue="md.X4MP_Spike_Capture.Globals.SpikeCapture_Stop"/>
        </do_if>
        <do_else>
          <signal_cue cue="md.X4MP_Spike_Capture.Globals.SpikeCapture_Start"/>
        </do_else>
        <include_actions ref="Capture_Button_Label"/>
        <signal_cue_instantly
          cue="md.Simple_Menu_API.Update_Widget"
          param="table[
            $id   = 'x4mp_spike_capture_toggle',
            $type = 'button',
            $text = table[$text = $CaptureButtonLabel],
            ]"/>
      </actions>
    </cue>
  </cues>
</mdscript>
